{
  "name": "indonesian-date",
  "version": "1.0.0",
  "description": "Indonesian date formatting & utilities — Senin, 16 Juli 2026, 2 hari yang lalu, WIB/WITA/WIT, dan lainnya.",
  "keywords": [
    "indonesia",
    "date",
    "tanggal",
    "format",
    "indonesian-date",
    "wib",
    "wita",
    "wit",
    "hari",
    "bulan",
    "relative-time",
    "date-fns"
  ],
  "license": "MIT",
  "author": "Abdan Zam Zam Ramadhan",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abdanzamzam/indonesian-date.git"
  },
  "bugs": {
    "url": "https://github.com/abdanzamzam/indonesian-date/issues"
  },
  "homepage": "https://github.com/abdanzamzam/indonesian-date#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
